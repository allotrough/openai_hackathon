# Keep false for the fully local deterministic demo.
VITE_TERRA_LIVE=false

# Server-side deployment variables (do not prefix these with VITE_).
# Pick `openai` or `openrouter`; keep the matching secret in your deployment secret manager.
LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.6-terra
# Reference-locked photo default. Seedream supports multi-image reference input;
# the server verifies capability before every cached routing decision.
OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
OPENROUTER_REFERENCE_IMAGE_MODEL=bytedance-seed/seedream-4.5
OPENROUTER_IMAGE_RESOLUTION=2K
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.6-terra
